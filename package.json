{
  "name": "clb-backend",
  "version": "1.0.0",
  "description": "CLB DApp Backend — Node.js + Fastify + Blockchain + PostgreSQL",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mobile": "npm --prefix CLBapp run start",
    "mobile:tunnel": "npm --prefix CLBapp run start -- --tunnel",
    "mobile:doctor": "npm --prefix CLBapp exec expo-doctor",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "android": "npm --prefix CLBapp run android",
    "ios": "npm --prefix CLBapp run ios",
    "e2e:transfer": "ts-node --transpile-only scripts/e2e-transfer-test.ts"
  },
  "keywords": [
    "blockchain",
    "dapp",
    "fastify",
    "prisma",
    "bsc"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "expo": "^54.0.0",
    "expo-dev-client": "~6.0.21",
    "fastify": "^4.28.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.5.4",
    "@types/react": "~19.1.10",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
