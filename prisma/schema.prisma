generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Wallet ─────────────────────────────────
model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  nonce         String    @default(uuid())
  username      String?
  email         String?   @unique
  avatar        String?
  passwordHash  String?
  referralCode  String?   @unique
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Security (PIN/biometric for mobile app)
  pinHash       String?
  pinSalt       String?
  biometricEnabled Boolean @default(false)
  tokenVersion  Int      @default(0)

  // Recovery key (encrypted) — like Trust Wallet backup phrase
  secretKey     String?   @unique
  secretKeyIv   String?

  // Relations
  deposits      Deposit[]
  referrals     Referral[]   @relation("referrer")
  referredBy    Referral?    @relation("referred")
  poolMemberships PoolMember[]
  transactions  Transaction[]
  notifications Notification[]
  loans         Loan[]
  tokenBalances TokenBalance[]
  transfersOut  TokenTransfer[] @relation("TransferFrom")
  transfersIn   TokenTransfer[] @relation("TransferTo")
  withdrawals   Withdrawal[]
  creditDraws   CreditDraw[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

// ─── Pool ───────────────────────────────────────────
model Pool {
  id              String      @id @default(uuid())
  name            String
  description     String?
  contractAddress String?
  tokenSymbol     String      @default("BNB")
  minDeposit      Decimal     @default(0)
  maxDeposit      Decimal?
  apy             Decimal     @default(0)
  totalStaked     Decimal     @default(0)
  status          PoolStatus  @default(ACTIVE)
  startDate       DateTime    @default(now())
  endDate         DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  deposits        Deposit[]
  members         PoolMember[]

  @@map("pools")
}

enum PoolStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// ─── Pool Member ────────────────────────────────────
model PoolMember {
  id        String   @id @default(uuid())
  userId    String
  poolId    String
  joinedAt  DateTime @default(now())
  share     Decimal  @default(0)

  user      User     @relation(fields: [userId], references: [id])
  pool      Pool     @relation(fields: [poolId], references: [id])

  @@unique([userId, poolId])
  @@map("pool_members")
}

// ─── Deposit ────────────────────────────────────────
model Deposit {
  id            String        @id @default(uuid())
  userId        String
  poolId        String?
  amount        Decimal
  amountUsd     Decimal?
  chain         String        @default("BNB")  // BTC, ETH, BNB, SOL etc.
  fromAddress   String?
  toAddress     String?
  txHash        String?       @unique
  status        DepositStatus @default(PENDING)
  confirmations Int           @default(0)
  confirmedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id])
  pool          Pool?         @relation(fields: [poolId], references: [id])
  loanId        String?
  loan          Loan?         @relation(fields: [loanId], references: [id])

  @@map("deposits")
}

enum DepositStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  FAILED
  REFUNDED
}

// ─── Referral ───────────────────────────────────────
model Referral {
  id           String         @id @default(uuid())
  referrerId   String
  referredId   String         @unique
  code         String         @unique
  reward       Decimal        @default(0)
  status       ReferralStatus @default(PENDING)
  createdAt    DateTime       @default(now())

  referrer     User           @relation("referrer", fields: [referrerId], references: [id])
  referred     User           @relation("referred", fields: [referredId], references: [id])

  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  ACTIVE
  REWARDED
  EXPIRED
}

// ─── Transaction Log ────────────────────────────────
model Transaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal
  txHash      String?         @unique
  fromAddress String?
  toAddress   String?
  status      TxStatus        @default(PENDING)
  metadata    Json?
  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  REWARD
  REFERRAL_BONUS
  FEE
  LOAN
  TRANSFER
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─── Notification ───────────────────────────────────
model Notification {
  id        String             @id @default(uuid())
  userId    String
  type      NotificationType   @default(INFO)
  title     String
  body      String
  isRead    Boolean            @default(false)
  data      Json?
  createdAt DateTime           @default(now())

  user      User               @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  INFO
  DEPOSIT
  WITHDRAWAL
  REWARD
  REFERRAL
  SECURITY
  POOL
  LOAN
  TRANSFER
}

// ─── Loan (Crypto-Backed Lending) ──────────────────
model Loan {
  id                 String     @id @default(uuid())
  userId             String
  loanType           LoanType   @default(FIXED_LOAN) // FIXED_LOAN or DYNAMIC_CREDIT
  collateralChain    String     // BTC, ETH, BNB — what user deposited
  collateralAmount   Decimal    // Amount of crypto deposited
  collateralPriceUsd Decimal    // USD price at time of loan
  collateralValueUsd Decimal    // Total USD value of collateral

  // For FIXED_LOAN: loanAmount is fixed at creation
  // For DYNAMIC_CREDIT: loanAmount = max credit limit at creation, drawnAmount = actually borrowed
  loanAmount         Decimal    // Max loan/credit amount (at current prices at creation time)
  drawnAmount        Decimal    @default(0) // For credit lines: amount actually drawn/borrowed
  availableCredit    Decimal    @default(0) // For credit lines: current available to borrow

  loanToken          String     @default("CLB") // CLB, CLBg, CLBs
  targetPriceUsd     Decimal?   // Price at which loan auto-settles (optional for credit lines)
  ltvPercent         Decimal    @default(50)  // Loan-to-value ratio
  interestRate       Decimal    @default(0)   // Annual interest rate
  liquidationPriceUsd Decimal?  // Price below which collateral is liquidated (downside)
  marginCallPriceUsd  Decimal?  // Price at which credit line enters margin call
  settlementPriceUsd Decimal?  // Actual price when loan was settled/liquidated
  profitUsd          Decimal?   // User profit (collateralValue at settlement - loanAmount)
  platformFeeUsd     Decimal?   // Platform fee from settlement
  status             LoanStatus @default(PENDING)
  lastCreditUpdateAt DateTime?  // Last time credit line was recalculated
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  settledAt          DateTime?
  liquidatedAt       DateTime?

  // Relations
  user               User       @relation(fields: [userId], references: [id])
  deposits           Deposit[]
  creditDraws        CreditDraw[] // History of credit draws and repayments

  @@index([userId, status])
  @@index([status, loanType])
  @@map("loans")
}

// ─── Credit Draw History (for DYNAMIC_CREDIT loans) ──────────────────
model CreditDraw {
  id              String   @id @default(uuid())
  loanId          String
  userId          String
  type            CreditDrawType
  amount          Decimal  // Amount drawn or repaid
  collateralPriceUsd Decimal // Price of collateral at time of transaction
  availableCreditAfter Decimal // Available credit after this transaction
  drawnAmountAfter Decimal     // Total drawn after this transaction
  txHash          String?  // Blockchain tx hash if applicable
  note            String?
  createdAt       DateTime @default(now())

  loan            Loan     @relation(fields: [loanId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([loanId])
  @@index([userId])
  @@map("credit_draws")
}

enum CreditDrawType {
  DRAW    // User drew/borrowed from credit line
  REPAY   // User repaid to credit line
  MARGIN_AUTO_REPAY // Automatic repayment due to margin call
  CREDIT_INCREASE // Credit increased due to collateral price rise
  CREDIT_DECREASE // Credit decreased due to collateral price fall
}

enum LoanStatus {
  PENDING      // Waiting for deposit confirmation
  ACTIVE       // Deposit confirmed, CLB tokens issued
  SETTLED      // Collateral price reached target, loan repaid
  LIQUIDATED   // Collateral value dropped too low
  CANCELLED    // User cancelled before deposit
  REPAID       // User manually repaid
  MARGIN_CALL  // Credit line in margin call - needs attention
}

enum LoanType {
  FIXED_LOAN        // Traditional fixed loan amount
  DYNAMIC_CREDIT    // Dynamic credit line that adjusts with collateral value
}

// ─── CLB Token Balances ────────────────────────────
model TokenBalance {
  id        String   @id @default(uuid())
  userId    String
  token     String   // CLB, CLBg, CLBs
  balance   Decimal  @default(0)
  locked    Decimal  @default(0)  // Locked in active loans
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, token])
  @@map("token_balances")
}

// ─── Token Transfer History ────────────────────────
model TokenTransfer {
  id          String         @id @default(uuid())
  fromUserId  String
  toUserId    String?
  toAddress   String?        // External wallet address
  token       String         // CLB, CLBg, CLBs
  amount      Decimal
  fee         Decimal        @default(0)
  type        TokenTransferType
  status      TokenTxStatus  @default(PENDING)
  txHash      String?        @unique
  note        String?
  createdAt   DateTime       @default(now())

  fromUser    User           @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser      User?          @relation("TransferTo", fields: [toUserId], references: [id])

  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@map("token_transfers")
}

enum TokenTransferType {
  INTERNAL     // Between platform users
  EXTERNAL     // To external wallet (e.g. Trust Wallet)
  LOAN_ISSUE   // Tokens issued from loan
  LOAN_REPAY   // Tokens returned on loan settlement
  REWARD       // Reward tokens
}

enum TokenTxStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── Withdrawal ────────────────────────────────────
model Withdrawal {
  id           String           @id @default(uuid())
  userId       String
  token        String           // CLB, CLBg, CLBs or BTC, ETH, BNB
  amount       Decimal
  toAddress    String
  fee          Decimal          @default(0)
  status       WithdrawalStatus @default(PENDING)
  txHash       String?          @unique
  createdAt    DateTime         @default(now())
  processedAt  DateTime?

  user         User             @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("withdrawals")
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}
