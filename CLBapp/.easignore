# EAS Build — shrink upload tarball (Pods + node_modules are huge; EAS reinstalls them).
# See: https://docs.expo.dev/build-reference/easignore/

# npm (reinstalled on EAS)
node_modules/

# iOS — CocoaPods + local build outputs only (keep Podfile / project for iOS builds)
ios/Pods/
ios/build/

# CocoaPods anywhere (defensive)
**/Pods/

# Expo / Metro / web
.expo/
dist/
web-build/
.metro-health-check*

# Android local caches (keep android/ Gradle project)
android/.gradle/
android/build/
android/app/build/
.gradle/

# Generic build dirs at repo root
build/

*.log
npm-debug.*
yarn-debug.*
yarn-error.*
.env*.local
.env.local

*.tsbuildinfo
.vscode/
.idea/

.DS_Store
**/.DS_Store

# Loose large file at repo root (not used by the app bundle)
/CLB logo.png
